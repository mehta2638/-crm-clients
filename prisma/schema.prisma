generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  company   String   @default("")
  status    String   @default("Новый")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}